{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "mesprefs",
	"main": "src/index.ts",
	"compatibility_date": "2024-01-01",
	"kv_namespaces": [
		{
			"binding": "MESPREFS",
			"id": "fe6dd50fc08947a29fd4fb74a873e3e9"
		}
	],
	"routes": [
		{
			"pattern": "mesprefs.francoiscote.net",
			"custom_domain": true
		}
	],
	"observability": {
		"logs": {
			"enabled": false,
			"invocation_logs": true
		}
	}
}